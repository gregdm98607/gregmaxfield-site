---
import Layout from '../layouts/Base.astro';
---

<Layout title="Books — Greg Maxfield" description="Novels and fiction by Greg Maxfield. Literary fiction rooted in the American West.">

<!-- PAGE HEADER -->
<section class="page-header">
  <div class="container content-narrow">
    <h1>Books</h1>
    <p class="page-header-sub">Literary fiction rooted in the landscapes and communities of the American West.</p>
  </div>
</section>

<!-- THE LUND COVENANT — FEATURED BOOK -->
<section class="books-list">
  <div class="container">

    <div class="book-entry reveal">
      <div class="book-entry-cover">
        <a href="/the-lund-covenant">
          <img
            src="/images/tlc-cover-front.jpg"
            alt="The Lund Covenant by Greg Maxfield"
            width="240"
            height="360"
            transition:name="tlc-cover"
          />
        </a>
      </div>
      <div class="book-entry-details">
        <p class="book-entry-label">Novel &middot; Literary Fiction</p>
        <h2><a href="/the-lund-covenant">The Lund Covenant</a></h2>
        <p class="book-entry-meta">Silver Sage Media &middot; June 2026 &middot; ~82,000 words</p>
        <p class="book-entry-blurb">
          When Gill Lund returns to Castle Dale, Utah after his father's death, he intends to stay three days.
          The town has other plans. A novel about moral inheritance, the cost of bearing witness, and what
          changes when a man decides to stay.
        </p>
        <p class="book-comps"><strong>For readers of:</strong> Kent Haruf, Marilynne Robinson, Ron Rash</p>

        <div class="book-entry-buy">
          <h3>Where to Buy</h3>
          <div class="buy-grid">
            <div class="buy-option">
              <p class="buy-option-label">Ebook &amp; Paperback</p>
              <a href="#" class="btn btn-primary">Amazon (KDP)</a>
            </div>
            <div class="buy-option">
              <p class="buy-option-label">Paperback &amp; Wide Distribution</p>
              <a href="#" class="btn btn-secondary">Bookshop.org</a>
            </div>
            <div class="buy-option">
              <p class="buy-option-label">Direct from the Author</p>
              <a href="#" class="btn btn-ghost">Buy on Gumroad &rarr;</a>
              <p class="buy-option-note">Ebook &amp; signed paperback options. Best price — supports the author directly.</p>
            </div>
          </div>
        </div>

        <div class="book-entry-links">
          <a href="/the-lund-covenant" class="text-link">Full description &amp; excerpt &rarr;</a>
          <a href="https://www.goodreads.com" target="_blank" rel="noopener" class="text-link">Add on Goodreads &rarr;</a>
          <a href="https://theunfoldingplot.substack.com" target="_blank" rel="noopener" class="text-link">Read the serialization on Substack &rarr;</a>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- COMING NEXT -->
<section class="coming-next reveal">
  <div class="container content-narrow" style="text-align:center;">
    <h2>More Coming</h2>
    <p>
      <em>The Lund Covenant</em> is the first novel in the Castle Dale series. A second novel is in
      early development. Subscribers to The Unfolding Plot get the first look at new work.
    </p>
    <a href="https://theunfoldingplot.substack.com" class="btn btn-secondary" target="_blank" rel="noopener">
      Follow on Substack
    </a>
  </div>
</section>

<!-- NEWSLETTER CTA -->
<section id="subscribe" class="subscribe-section">
  <div class="container content-narrow reveal" style="text-align:center;">
    <h2>Stay in the Loop</h2>
    <p>Launch updates, behind-the-scenes notes, and early access for readers on the list.</p>

    <form id="kit-books-form" class="kit-form" aria-label="Newsletter signup">
      <div class="kit-form-fields">
        <input
          type="text"
          name="first_name"
          placeholder="First name"
          class="kit-input"
          autocomplete="given-name"
        />
        <input
          type="email"
          name="email"
          placeholder="Email address"
          class="kit-input"
          required
          autocomplete="email"
        />
        <button type="submit" class="btn btn-primary kit-submit">
          <span class="kit-submit-text">Subscribe</span>
          <span class="kit-submit-loading" style="display:none;">Subscribing…</span>
        </button>
      </div>
      <p class="kit-form-note">No spam. Unsubscribe anytime.</p>
    </form>
    <div id="kit-books-success" class="kit-message kit-success" style="display:none;">
      <p><strong>You're in.</strong> Check your inbox for a confirmation email.</p>
    </div>
    <div id="kit-books-error" class="kit-message kit-error" style="display:none;">
      <p>Something went wrong. Please try again, or email <a href="mailto:greg@gregmaxfield.com" style="color:var(--color-accent);">greg@gregmaxfield.com</a>.</p>
    </div>
  </div>
</section>

<style>
  /* Page header */
  .page-header {
    padding: 4rem 1.5rem 2rem;
    text-align: center;
  }
  .page-header h1 {
    margin-bottom: 0.5rem;
  }
  .page-header-sub {
    color: var(--color-text-light);
    font-size: 1.1rem;
    max-width: 480px;
    margin: 0 auto;
  }

  /* Book entries */
  .books-list {
    padding: 2rem 1.5rem 3rem;
  }
  .book-entry {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 3rem;
    align-items: start;
    max-width: 900px;
    margin: 0 auto 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--color-border, rgba(0,0,0,0.08));
  }
  .book-entry:last-child {
    border-bottom: none;
  }
  .book-entry-cover img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .book-entry-cover img:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 40px rgba(0,0,0,0.2);
  }
  .book-entry-label {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }
  .book-entry-details h2 {
    margin: 0 0 0.25rem;
    font-size: 1.9rem;
  }
  .book-entry-details h2 a {
    color: inherit;
    text-decoration: none;
  }
  .book-entry-details h2 a:hover {
    color: var(--color-accent);
  }
  .book-entry-meta {
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }
  .book-entry-blurb {
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  /* Buy grid */
  .book-entry-buy {
    margin-top: 1.75rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-border, rgba(0,0,0,0.08));
  }
  .book-entry-buy h3 {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }
  .buy-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    align-items: flex-start;
  }
  .buy-option {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .buy-option-label {
    font-size: 0.8rem;
    color: var(--color-text-light);
    margin: 0;
  }
  .buy-option-note {
    font-size: 0.78rem;
    color: var(--color-text-light);
    max-width: 200px;
    margin: 0;
  }

  /* Text links */
  .book-entry-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .text-link {
    font-size: 0.9rem;
    color: var(--color-accent);
    text-decoration: none;
  }
  .text-link:hover {
    text-decoration: underline;
  }

  /* Coming next */
  .coming-next {
    padding: 3rem 1.5rem;
    background: var(--color-surface, rgba(0,0,0,0.03));
  }
  .coming-next h2 {
    margin-bottom: 0.75rem;
  }
  .coming-next p {
    max-width: 520px;
    margin: 0 auto 1.5rem;
    color: var(--color-text-light);
  }

  /* Kit form (mirrors homepage) */
  .kit-form { margin-top: 1.5rem; }
  .kit-form-fields {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    max-width: 560px;
    margin: 0 auto;
  }
  .kit-input {
    flex: 1;
    min-width: 160px;
    padding: 0.8rem 1.2rem;
    border: 2px solid rgba(250,248,245,0.3);
    border-radius: var(--radius);
    background: rgba(250,248,245,0.1);
    color: var(--color-bg);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color var(--transition), background var(--transition);
  }
  .kit-input::placeholder { color: rgba(250,248,245,0.5); }
  .kit-input:focus {
    outline: none;
    border-color: var(--color-accent);
    background: rgba(250,248,245,0.15);
  }
  .kit-submit { min-width: 140px; white-space: nowrap; }
  .kit-form-note { font-size: 0.85rem; margin-top: 0.75rem; color: rgba(250,248,245,0.6); }
  .kit-message { margin-top: 1.5rem; padding: 1.25rem 1.5rem; border-radius: var(--radius); }
  .kit-success { background: rgba(250,248,245,0.12); border: 1px solid rgba(250,248,245,0.25); }
  .kit-error { background: rgba(200,50,50,0.15); border: 1px solid rgba(200,50,50,0.3); }
  .kit-message p { margin: 0; font-size: 1rem; }

  /* Responsive */
  @media (max-width: 680px) {
    .book-entry {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .book-entry-cover {
      max-width: 200px;
      margin: 0 auto;
    }
    .kit-form-fields {
      flex-direction: column;
    }
    .kit-input, .kit-submit {
      width: 100%;
      min-width: auto;
    }
  }
</style>

<script>
  // Scroll-reveal
  const reveals = document.querySelectorAll('.reveal');
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { rootMargin: '0px 0px -80px 0px' });
  reveals.forEach(el => revealObserver.observe(el));

  // Kit signup
  const KIT_API_KEY = '1DPMCQ3iN_j0o-HFQ_sRLA';
  const TAG_GMA_NEWSLETTER = 18895877;
  const TAG_TLC_LAUNCH = 18895878;

  const form = document.getElementById('kit-books-form');
  const successEl = document.getElementById('kit-books-success');
  const errorEl = document.getElementById('kit-books-error');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const email = formData.get('email');
      const firstName = formData.get('first_name');
      if (!email) return;

      const submitText = form.querySelector('.kit-submit-text');
      const submitLoading = form.querySelector('.kit-submit-loading');
      const submitBtn = form.querySelector('.kit-submit');
      if (submitText) submitText.style.display = 'none';
      if (submitLoading) submitLoading.style.display = 'inline';
      if (submitBtn) submitBtn.disabled = true;
      successEl.style.display = 'none';
      errorEl.style.display = 'none';

      try {
        const body = JSON.stringify({ api_key: KIT_API_KEY, email, first_name: firstName || undefined });
        const [res1, res2] = await Promise.all([
          fetch(`https://api.convertkit.com/v3/tags/${TAG_GMA_NEWSLETTER}/subscribe`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body,
          }),
          fetch(`https://api.convertkit.com/v3/tags/${TAG_TLC_LAUNCH}/subscribe`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body,
          }),
        ]);
        if (res1.ok) {
          form.style.display = 'none';
          successEl.style.display = 'block';
        } else {
          throw new Error('Subscription failed');
        }
      } catch (err) {
        errorEl.style.display = 'block';
      } finally {
        if (submitText) submitText.style.display = 'inline';
        if (submitLoading) submitLoading.style.display = 'none';
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>

</Layout>
