---
import Layout from '../layouts/Base.astro';
---

<Layout title="Greg Maxfield — Author" description="Literary fiction rooted in the American West. Home of The Lund Covenant.">

<!-- HERO (W1: parallax desert backdrop) -->
<section id="hero" class="hero">
  <div class="hero-backdrop"></div>
  <div class="hero-inner">
    <div class="hero-text">
      <h1>Greg Maxfield</h1>
      <p class="hero-tagline">Literary fiction rooted in the landscape, history, and moral tensions of the American West.</p>
      <div class="hero-cta">
        <a href="/the-lund-covenant" class="btn btn-primary">Discover The Lund Covenant</a>
        <a href="https://theunfoldingplot.substack.com" class="btn btn-secondary" target="_blank" rel="noopener">Read on Substack</a>
      </div>
    </div>
    <div class="hero-image">
      <img
        src="/images/tlc-cover-hero.jpg"
        alt="The Lund Covenant — book cover"
        width="360"
        height="540"
        transition:name="tlc-cover"
      />
    </div>
  </div>
</section>
<!-- THE BOOK -->
<section id="the-book" class="book-section">
  <div class="container reveal">
    <div class="book-layout">
      <div class="book-cover">
        <img src="/images/tlc-cover-front.jpg" alt="The Lund Covenant by Greg Maxfield" width="320" height="480" />
      </div>
      <div class="book-details">
        <h2>The Lund Covenant</h2>
        <p class="book-genre">Literary Fiction &middot; July 2026</p>
        <p class="book-blurb">
          A photojournalist returns to the small Utah town he left behind — and finds it tangled in a crisis
          that forces him to choose between the comfortable silence of home and the cost of seeing clearly.
        </p>
        <p class="book-blurb">
          <em>The Lund Covenant</em> is a novel about complicity, memory, and what it means to bear witness
          in a place that would rather you didn't.
        </p>
        <p class="book-comps"><strong>For readers of:</strong> Kent Haruf, Marilynne Robinson, Denis Johnson</p>
        <div class="book-cta">
          <a href="/the-lund-covenant" class="btn btn-primary">Learn More</a>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- PROJECTS -->
<section id="projects" class="projects-section">
  <div class="container">
    <h2 style="text-align:center;" class="reveal">More From Greg</h2>
    <div class="projects-grid">
      <div class="project-card reveal">
        <h3>Operation Granny Files</h3>
        <p>A family history project that turns genealogy into story — real ancestors, real documents, real narrative. Two thousand readers and counting.</p>
        <a href="https://operationgrannyfiles.com" class="btn btn-ghost" target="_blank" rel="noopener">Visit OGF &rarr;</a>
      </div>
      <div class="project-card reveal">
        <h3>Conduital</h3>
        <p>A personal productivity system for connecting what you know to what you're building — notes, projects, and actions in one flow.</p>
        <a href="https://conduital.com" class="btn btn-ghost" target="_blank" rel="noopener">Visit Conduital &rarr;</a>
      </div>
      <div class="project-card reveal">
        <h3>The Unfolding Plot</h3>
        <p><em>The Lund Covenant</em>, serialized chapter by chapter on Substack — read the novel as it unfolds.</p>
        <a href="https://theunfoldingplot.substack.com" class="btn btn-ghost" target="_blank" rel="noopener">Read on Substack &rarr;</a>
      </div>
    </div>
  </div>
</section>
<!-- ABOUT THE AUTHOR -->
<section id="about" class="about-section">
  <div class="container content-narrow reveal">
    <h2>About the Author</h2>
    <div class="about-layout">
      <div class="about-photo">
        <img src="/images/greg-headshot.jpg" alt="Greg Maxfield" width="160" height="160" />
      </div>
      <div class="about-text">
        <p>
          Greg Maxfield writes literary fiction set in the landscapes and communities of the American West.
          His work explores the intersections of family obligation, cultural memory, and moral reckoning
          in places where history isn't past — it's the ground you're standing on.
        </p>
        <p>
          A native of Emery County, Utah, he spent three decades in the energy industry before turning
          full-time to writing. He lives in the Pacific Northwest, where he also runs
          <a href="https://operationgrannyfiles.substack.com" target="_blank" rel="noopener">Operation Granny Files</a>
          and builds productivity tools at
          <a href="https://conduital.com" target="_blank" rel="noopener">Conduital</a>.
        </p>
      </div>
    </div>
  </div>
</section>
<!-- NEWSLETTER SIGNUP -->
<section id="subscribe" class="subscribe-section">
  <div class="container content-narrow reveal" style="text-align:center;">
    <h2>Follow the Story</h2>
    <p>Get launch updates, early access, and behind-the-scenes notes on the writing process. No spam. Unsubscribe anytime.</p>

    <form id="kit-signup-form" class="kit-form" aria-label="Newsletter signup">
      <div class="kit-form-fields">
        <input
          type="text"
          name="first_name"
          placeholder="First name"
          class="kit-input"
          autocomplete="given-name"
        />
        <input
          type="email"
          name="email"
          placeholder="Email address"
          class="kit-input"
          required
          autocomplete="email"
        />
        <button type="submit" class="btn btn-primary kit-submit">
          <span class="kit-submit-text">Subscribe</span>
          <span class="kit-submit-loading" style="display:none;">Subscribing…</span>
        </button>
      </div>
      <p class="kit-form-note">Join the mailing list for <em>The Lund Covenant</em> launch updates and more.</p>
    </form>
    <div id="kit-success" class="kit-message kit-success" style="display:none;">
      <p><strong>You're in.</strong> Check your inbox for a confirmation email. Welcome aboard.</p>
    </div>

    <div id="kit-error" class="kit-message kit-error" style="display:none;">
      <p>Something went wrong. Please try again, or email <a href="mailto:greg@gregmaxfield.com" style="color:var(--color-accent);">greg@gregmaxfield.com</a> directly.</p>
    </div>

    <p style="margin-top:1.5rem; font-size:0.9rem;">
      Already reading? Find Greg on Substack:<br/>
      <a href="https://theunfoldingplot.substack.com" target="_blank" rel="noopener" style="color:var(--color-accent);">The Unfolding Plot</a> &middot;
      <a href="https://operationgrannyfiles.substack.com" target="_blank" rel="noopener" style="color:var(--color-accent);">Operation Granny Files</a>
    </p>
  </div>
</section>
<style>
  /* W1: Parallax hero backdrop */
  .hero {
    position: relative;
    overflow: hidden;
  }
  .hero-backdrop {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(250,248,245,0.95), rgba(250,248,245,0.6)),
      linear-gradient(135deg, #E8D5C4 0%, #D4B896 40%, #C4A882 70%, #B89B7A 100%);
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
  }

  /* Kit signup form */
  .kit-form {
    margin-top: 1.5rem;
  }
  .kit-form-fields {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    max-width: 560px;
    margin: 0 auto;
  }  .kit-input {
    flex: 1;
    min-width: 160px;
    padding: 0.8rem 1.2rem;
    border: 2px solid rgba(250,248,245,0.3);
    border-radius: var(--radius);
    background: rgba(250,248,245,0.1);
    color: var(--color-bg);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color var(--transition), background var(--transition);
  }
  .kit-input::placeholder {
    color: rgba(250,248,245,0.5);
  }
  .kit-input:focus {
    outline: none;
    border-color: var(--color-accent);
    background: rgba(250,248,245,0.15);
  }
  .kit-submit {
    min-width: 140px;
    white-space: nowrap;
  }
  .kit-form-note {
    font-size: 0.85rem;
    margin-top: 0.75rem;
    color: rgba(250,248,245,0.6);
  }  .kit-message {
    margin-top: 1.5rem;
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius);
  }
  .kit-success {
    background: rgba(250,248,245,0.12);
    border: 1px solid rgba(250,248,245,0.25);
  }
  .kit-error {
    background: rgba(200,50,50,0.15);
    border: 1px solid rgba(200,50,50,0.3);
  }
  .kit-message p {
    margin: 0;
    font-size: 1rem;
  }

  @media (max-width: 480px) {
    .kit-form-fields {
      flex-direction: column;
    }
    .kit-input, .kit-submit {
      width: 100%;
      min-width: auto;
    }
  }
</style>
<script>
  // U1: Intersection Observer for active-section highlighting
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-links a[href^="/#"]');

  const sectionObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navLinks.forEach(link => {
          const href = link.getAttribute('href');
          link.classList.toggle('active', href === '/#' + id || href === '#' + id);
        });
      }
    });
  }, { rootMargin: '-40% 0px -60% 0px' });

  sections.forEach(section => sectionObserver.observe(section));

  // U5: Scroll-reveal animations
  const reveals = document.querySelectorAll('.reveal');
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { rootMargin: '0px 0px -80px 0px' });

  reveals.forEach(el => revealObserver.observe(el));
  // Kit newsletter signup
  const KIT_API_KEY = '1DPMCQ3iN_j0o-HFQ_sRLA';
  const TAG_GMA_NEWSLETTER = 18895877;
  const TAG_TLC_LAUNCH = 18895878;

  const form = document.getElementById('kit-signup-form');
  const successEl = document.getElementById('kit-success');
  const errorEl = document.getElementById('kit-error');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const email = formData.get('email');
      const firstName = formData.get('first_name');

      if (!email) return;

      // UI: show loading state
      const submitText = form.querySelector('.kit-submit-text');
      const submitLoading = form.querySelector('.kit-submit-loading');
      const submitBtn = form.querySelector('.kit-submit');
      if (submitText) submitText.style.display = 'none';
      if (submitLoading) submitLoading.style.display = 'inline';
      if (submitBtn) submitBtn.disabled = true;
      successEl.style.display = 'none';
      errorEl.style.display = 'none';
      try {
        // Subscribe to both tags in parallel
        const body = JSON.stringify({
          api_key: KIT_API_KEY,
          email: email,
          first_name: firstName || undefined,
        });

        const [res1, res2] = await Promise.all([
          fetch(`https://api.convertkit.com/v3/tags/${TAG_GMA_NEWSLETTER}/subscribe`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: body,
          }),
          fetch(`https://api.convertkit.com/v3/tags/${TAG_TLC_LAUNCH}/subscribe`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: body,
          }),
        ]);

        if (res1.ok) {
          form.style.display = 'none';
          successEl.style.display = 'block';
        } else {
          throw new Error('Subscription failed');
        }
      } catch (err) {
        errorEl.style.display = 'block';
      } finally {
        if (submitText) submitText.style.display = 'inline';
        if (submitLoading) submitLoading.style.display = 'none';
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>
</Layout>
