---
import Layout from '../layouts/Base.astro';
---

<Layout
  title="Page Not Found — Greg Maxfield"
  description="This page has wandered off the map. Find your way back to Greg Maxfield's work and The Lund Covenant."
>

<section class="notfound">
  <div class="container content-narrow notfound-inner">
    <p class="notfound-code">404</p>
    <h1>This page has wandered off the map.</h1>
    <p class="notfound-lede">
      Like a trail that peters out in the sagebrush, the page you're looking for
      isn't here anymore — or never was. Let's get you back to solid ground.
    </p>
    <div class="notfound-cta">
      <a href="/" class="btn btn-primary">Back Home</a>
      <a href="/the-lund-covenant" class="btn btn-secondary">The Lund Covenant</a>
      <a href="/blog" class="btn btn-ghost">Read the Blog</a>
    </div>
  </div>
</section>

<style>
  .notfound {
    background: var(--color-bg);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  .notfound-inner {
    text-align: center;
  }
  .notfound-code {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(5rem, 18vw, 9rem);
    line-height: 1;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }
  .notfound h1 {
    font-size: clamp(1.6rem, 5vw, 2.5rem);
    margin-bottom: 1rem;
  }
  .notfound-lede {
    font-size: 1.1rem;
    color: var(--color-text-light);
    max-width: 36rem;
    margin: 0 auto 2rem;
  }
  .notfound-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>

</Layout>
