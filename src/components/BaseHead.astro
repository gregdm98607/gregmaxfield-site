---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { SITE_TITLE } from '../consts';
import StructuredData from './StructuredData.astro';
import { websiteNode, organizationNode } from '../data/schema';

interface Props {
	title: string;
	description: string;
	image?: string;
	imageAlt?: string;
	noindex?: boolean;
	ogType?: string;
	publishedTime?: string;
	modifiedTime?: string;
	jsonLd?: Record<string, unknown>[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	image = '/images/og-image.png',
	imageAlt = 'Greg Maxfield, author of the literary novel The Lund Covenant',
	noindex = false,
	ogType = 'website',
	publishedTime,
	modifiedTime,
	jsonLd = [],
} = Astro.props;

// Default OG image (og-image.png) is 1200x630. Override imageAlt per page.
const TWITTER_HANDLE = '@Greg_Maxfield5';

// Sitewide entities (WebSite + Organization) are always present; page-specific
// nodes (Person, Book, BlogPosting, FAQPage) append via the jsonLd prop.
const graph = [websiteNode(), organizationNode(), ...jsonLd];
---

<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-BNVECLV39M"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-BNVECLV39M');
</script>

<!-- GA4: track pageviews on client-side navigation (B2).
     Module script — runs once, registers an astro:page-load listener that fires on every nav.
     Skips the first load (already covered by the config call above).
     Uses window.gtag which is defined by gtag.js once it loads. -->
<script>
  let isFirstPageLoad = true;
  document.addEventListener('astro:page-load', () => {
    if (isFirstPageLoad) { isFirstPageLoad = false; return; }
    if (typeof window.gtag === 'function') {
      window.gtag('event', 'page_view', {
        page_path: window.location.pathname,
        page_title: document.title,
      });
    }
  });
</script>

<!-- Site Verification -->
<meta name='impact-site-verification' value='4b4ebd26-9e7e-42e9-bdbf-735b17703cb5'>

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Google Fonts: Playfair Display + Inter -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Indexing -->
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="Greg Maxfield" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={imageAlt} />

<!-- Article metadata (SEO-03) — emitted only for blog posts. -->
{ogType === 'article' && (
	<>
		{publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
		<meta property="article:author" content="Greg Maxfield" />
	</>
)}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:site" content={TWITTER_HANDLE} />
<meta property="twitter:creator" content={TWITTER_HANDLE} />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />
<meta property="twitter:image:alt" content={imageAlt} />

<!-- Structured data (SEO-01/02, LLM-01, LLM-03) — one @graph per page. -->
<StructuredData schema={graph} />
