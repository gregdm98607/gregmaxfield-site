---
// Reusable JSON-LD emitter (SEO-01). Accepts one node or an array of nodes and
// renders them as a single schema.org @graph. Cross-node @id references resolve
// within the graph. Used by BaseHead so every page gets one clean ld+json block.
interface Props {
	schema: Record<string, unknown> | Record<string, unknown>[];
}

const { schema } = Astro.props;
const nodes = Array.isArray(schema) ? schema : [schema];
const json = JSON.stringify({ '@context': 'https://schema.org', '@graph': nodes });
---

<script type="application/ld+json" is:inline set:html={json} />
